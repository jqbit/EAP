{
  "name": "eap-protocol",
  "version": "0.1.0",
  "description": "EAP — Efficient Agent Protocol. Compress agent tokens at all three membranes: input (Context), working (Runtime), output (Signal). MIT, self-contained, honest claims.",
  "license": "MIT",
  "author": "ZeroPointNineBar",
  "homepage": "https://0point9bar.github.io/EAP/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0point9bar/EAP.git"
  },
  "bugs": {
    "url": "https://github.com/0point9bar/EAP/issues"
  },
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:py": "python3 tests/test_context_engine.py",
    "bench": "python3 bench/run.py",
    "check": "bash scripts/check-contamination.sh",
    "eap": "node bin/eap-install.mjs",
    "eap:list": "node bin/eap-install.mjs --list",
    "eap:install": "node bin/eap-install.mjs --only claude",
    "eap:uninstall": "node bin/eap-install.mjs --uninstall"
  },
  "bin": { "eap-install": "bin/eap-install.mjs" },
  "keywords": [
    "ai-agents", "context-engineering", "token-reduction", "mcp",
    "code-graph", "retrieval", "output-compression", "efficient-agent-protocol"
  ],
  "files": [
    "EAP.md", "LICENSE", "NOTICE", "README.md", "install.sh", "install.ps1",
    "layers/", "layers/eap-lean/", "docs/", "bench/", "scripts/", "bin/", "src/"
  ]
}
